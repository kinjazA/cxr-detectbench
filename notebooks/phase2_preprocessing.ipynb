   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!python scripts/label_fusion.py \\\n",
    "    --train_csv data/raw/train.csv \\\n",
    "    --images_csv data/raw/images.csv \\\n",
    "    --output_dir data/processed/labels_coco \\\n",
    "    --iou_thr 0.5"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!python scripts/check_fusion_output.py"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Fusion Ablation (YOLOv8n 20ep x3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!python scripts/run_fusion_ablation.py \\\n",
    "    --coco_dir data/processed/labels_coco \\\n",
    "    --images_dir data/processed/images_png \\\n",
    "    --train_csv data/raw/train.csv \\\n",
    "    --epochs 20 \\\n",
    "    --imgsz 640 \\\n",
    "    --batch 16 \\\n",
    "    --output phase2_fusion_ablation.csv"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "result_path = Path('phase2_fusion_ablation.csv')\n",
    "if result_path.exists():\n",
    "    df = pd.read_csv(result_path)\n",
    "    print(\"\\n\" + \"=\"*60)\n",
    "    print(\"Phase 2.4 Fusion Ablation Results\")\n",
    "    print(\"=\"*60)\n",
    "    print(df.to_string(index=False))\n",
    "    valid = df[df['mAP50'] > 0]\n",
    "    if len(valid):\n",
    "        best = valid.loc[valid['mAP50'].idxmax(), 'fusion_mode']\n",
    "        print(f\"\\nBest fusion: {best}\")\n",
    "else:\n",
    "    print('No results yet')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Generate Final YOLO Labels"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
