   "source": [
    "# CXR-DetectBench Phase 2 - Data Preprocessing"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Environment Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install -q ensemble-boxes pycocotools opencv-python-headless ultralytics scikit-learn tqdm matplotlib"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# GPU compatibility check: P100 (sm_60) needs PyTorch <= 2.4\n",
    "# Kaggle's default PyTorch 2.10 dropped sm_60 support\n",
    "import subprocess, sys\n",
    "\n",
    "def check_gpu():\n",
    "    try:\n",
    "        out = subprocess.check_output(['nvidia-smi', '--query-gpu=name', '--format=csv,noheader'], encoding='utf-8')\n",
    "        return out.strip()\n",
    "    except:\n",
    "        return 'unknown'\n",
    "\n",
    "gpu_name = check_gpu()\n",
    "print(f'GPU: {gpu_name}')\n",
    "\n",
    "if 'P100' in gpu_name:\n",
    "    print('P100 detected! Installing PyTorch 2.4 (compatible with sm_60)...')\n",
    "    subprocess.check_call([sys.executable, '-m', 'pip', 'install', '-q',\n",
    "        'torch==2.4.0', 'torchvision==0.19.0',\n",
    "        '--index-url', 'https://download.pytorch.org/whl/cu121'])\n",
    "    print('PyTorch 2.4 installed. Restart required in notebook.')\n",
    "elif 'T4' in gpu_name:\n",
    "    print('T4 detected! Current PyTorch is compatible.')\n",
    "elif 'unknown' in gpu_name:\n",
    "    print('Cannot detect GPU, proceeding with default PyTorch...')\n",
    "else:\n",
    "    print(f'GPU {gpu_name} - proceeding with default PyTorch...')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Verify PyTorch CUDA compatibility\n",
    "import torch\n",
    "print(f'PyTorch: {torch.__version__}')\n",
    "print(f'CUDA available: {torch.cuda.is_available()}')\n",
    "if torch.cuda.is_available():\n",
    "    print(f'CUDA device: {torch.cuda.get_device_name(0)}')\n",
    "    x = torch.zeros(1).cuda()\n",
    "    print('GPU works!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Explore Inputs"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "from pathlib import Path\n",
    "\n",
    "os.chdir('/kaggle/working')\n",
    "\n",
    "print(\"=== /kaggle/input/ directories ===\")\n",
    "!ls -la /kaggle/input/"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Clone Repository"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!git clone https://github.com/kinjazA/cxr-detectbench.git\n",
    "%cd cxr-detectbench"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Prepare Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!mkdir -p data/raw data/processed\n",
    "\n",
    "# Copy train.csv (search multiple paths)\n",
    "import subprocess\n",
    "\n",
    "train_found = False\n",
    "for p in Path('/kaggle/input').rglob('train.csv'):\n",
    "    print(f'Copying train.csv from {p}')\n",
    "    !cp '{p}' data/raw/train.csv\n",
    "    train_found = True\n",
    "    break\n",
    "\n",
    "if not train_found:\n",
    "    print('Downloading train.csv...')\n",
    "    !kaggle competitions download vinbigdata-chest-xray-abnormalities-detection -f train.csv -p data/raw/\n",
    "\n",
    "# Copy images.csv (DICOM metadata)\n",
    "img_found = False\n",
    "for name in ['train_meta.csv', 'images.csv', 'image_meta.csv']:\n",
    "    for p in Path('/kaggle/input').rglob(name):\n",
    "        print(f'Copying {name} from {p}')\n",
    "        !cp '{p}' data/raw/images.csv\n",
    "        img_found = True\n",
    "        break\n",
    "    if img_found:\n",
    "        break\n",
    "\n",
    "# Link PNG images\n",
    "!ln -sf /kaggle/input/vinbigdata-chest-xray-original-png/train data/processed/images_png 2>/dev/null || true\n",
    "\n",
    "print(\"\\n=== data/raw/ ===\")\n",
    "!ls -lh data/raw/\n",
    "print(\"\\n=== data/processed/ ===\")\n",
    "!ls -lh data/processed/"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
